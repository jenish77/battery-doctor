## Battery Doctor Admin Panel - Environment Variables
## Copy this file to .env.local and fill in the values

# =============================================================
# API Configuration
# =============================================================

# Backend API Base URL (the actual backend server)
# Change this to your local backend when developing locally
# Examples:
#   Live:  https://batterydoctor.elvee.app/api
#   Local: http://localhost:5000/api
NEXT_PUBLIC_API_BASE_URL=https://batterydoctor.elvee.app/api

# Use proxy to avoid CORS? (true = calls go through /api proxy, false = direct calls)
# Set to "false" if your backend has CORS configured for your domain
# Set to "true" for local development to avoid CORS issues
NEXT_PUBLIC_USE_PROXY=true

# =============================================================
# App Configuration
# =============================================================

# Environment header sent to backend (test | production)
NEXT_PUBLIC_ENV=test

# Device header sent to backend
NEXT_PUBLIC_DEVICE=web
